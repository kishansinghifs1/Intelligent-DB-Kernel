# Application
PORT=3001
NODE_ENV=production

# MongoDB
ATLAS_DB_URL=mongodb+srv://<username>:<password>@<cluster-host>/<db-name>
MONGODB_CONNECT_TIMEOUT_MS=20000

# JWT
JWT_SECRET=<strong-access-token-secret>
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=<strong-refresh-token-secret>
JWT_REFRESH_EXPIRES_IN=7d

# AWS S3 Settings for Profile Pictures
AWS_REGION=us-east-1
S3_BUCKET_NAME=<your-s3-bucket-name>
AWS_ACCESS_KEY_ID=<your-aws-access-key-id>
AWS_SECRET_ACCESS_KEY=<your-aws-secret-access-key>

# Redis settings (cache + distributed rate limiter)
REDIS_ENABLED=true
REDIS_URL=rediss://default:<redis-password>@<redis-host>:<redis-port>
REDIS_HOST=<redis-host>
REDIS_PORT=<redis-port>
REDIS_PASSWORD=<redis-password>
REDIS_DB=0
REDIS_KEY_PREFIX=user-service

# User profile cache TTL (seconds)
USER_PROFILE_CACHE_TTL_SECONDS=120

# Rate limiter settings
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=10
USER_API_RATE_LIMIT_WINDOW_MS=60000
USER_API_RATE_LIMIT_MAX=120
